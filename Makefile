# ==========================================
# 1. 自動ディレクトリ抽出（棚卸し）
# ==========================================
# wildcard */ : カレントディレクトリにある「すべてのディレクトリ」を取得。
#                結果は "common/ cp/ more/ who/" のようになります（末尾に / が付く）。
# subst /,,   : スラッシュ(/)を空(,,)に置き換えて消します。
#                "common cp more who" になります。
# filter-out  : 指定した単語（common）をリストから除外します。
#                結果、SUBDIRS 変数は "cp more who" になります。
SUBDIRS := $(filter-out common, $(subst /,,$(wildcard */)))

# ==========================================
# 2. 特殊設定（ターゲットの保護）
# ==========================================
# .PHONY: 本来 make は「同名のファイル」があると動きませんが、
#          これに登録しておくとファイルがあっても必ず実行されます。
#          「all や clean というファイルを探すな、命令として実行せよ」という宣言。
.PHONY: all clean $(SUBDIRS)

# ==========================================
# 3. 再帰ビルドのルール（一括指示）
# ==========================================

# "make" と打つと、自動でリストアップされた全ディレクトリを処理しに行きます。
all: $(SUBDIRS)

# $(SUBDIRS): ここが Make の面白いところなのかな。
# 変数の中身（cp more who）がそれぞれ「ターゲット」になる。
$(SUBDIRS):
	# $(MAKE): make コマンド自身を呼び出します。
	# -C $@  : "-C" は Change directory の略。
	#          "$@" はターゲット名（例: cp）が入ります。
	# つまり「cp ディレクトリに移動して、そこで make を実行せよ」という意味です。
	$(MAKE) -C $@

# ==========================================
# 4. 一括お掃除（全体清掃）
# ==========================================
clean:
	@# ここはシェルの for 文です。
	@# リストにあるディレクトリを一つずつ巡回して、それぞれの clean を実行します。
	@for dir in $(SUBDIRS); do \
		$(MAKE) -C $$dir clean; \
	done
